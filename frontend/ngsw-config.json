{
  "$schema": "./node_modules/@angular/service-worker/config/schema.json",
  "index": "/index.html",
  "assetGroups": [
    {
      "name": "app",
      "installMode": "prefetch",
      "resources": {
        "files": [
          "/favicon.ico",
          "/index.html",
          "/manifest.webmanifest",
          "/*.css",
          "/*.js"
        ]
      }
    },
    {
      "name": "assets",
      "installMode": "lazy",
      "updateMode": "prefetch",
      "resources": {
        "files": [
          "/assets/**",
          "/media/*.(svg|cur|jpg|jpeg|png|apng|webp|avif|gif|otf|ttf|woff|woff2)"
        ]
      }
    }
  ],
  "dataGroups": [
    {
      "name": "api-boards",
      "urls": ["/boards/", "/boards/*/"],
      "cacheConfig": {
        "maxSize": 50,
        "maxAge": "1h",
        "strategy": "freshness",
        "timeout": "5s"
      }
    },
    {
      "name": "api-tasks",
      "urls": ["/tasks/*"],
      "cacheConfig": {
        "maxSize": 200,
        "maxAge": "1h",
        "strategy": "freshness",
        "timeout": "5s"
      }
    },
    {
      "name": "api-user",
      "urls": ["/auth/me/", "/notifications/", "/contacts/"],
      "cacheConfig": {
        "maxSize": 20,
        "maxAge": "30m",
        "strategy": "freshness",
        "timeout": "5s"
      }
    }
  ]
}
