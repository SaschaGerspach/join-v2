# Django
DJANGO_SECRET_KEY=change-me-to-a-long-random-string
DJANGO_DEBUG=false
DJANGO_ALLOWED_HOSTS=join.api.sascha-gerspach.de
CORS_ALLOWED_ORIGINS=https://join.sascha-gerspach.de
CSRF_TRUSTED_ORIGINS=https://join.sascha-gerspach.de
FRONTEND_URL=https://join.sascha-gerspach.de

# Cookies (Default: automatisch Secure+SameSite=None wenn DJANGO_DEBUG=false, sonst Lax/not-secure)
# SESSION_COOKIE_SECURE=true
# CSRF_COOKIE_SECURE=true
# SESSION_COOKIE_SAMESITE=None
# CSRF_COOKIE_SAMESITE=None

# PostgreSQL
POSTGRES_DB=join
POSTGRES_USER=join
POSTGRES_PASSWORD=change-me
POSTGRES_HOST=db

# Email (optional — defaults to console output if not set)
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_USE_TLS=true
EMAIL_HOST_USER=noreply@example.com
EMAIL_HOST_PASSWORD=smtp-password
DEFAULT_FROM_EMAIL=noreply@example.com

# Nginx / Certbot (Backend-Domain, muss per DNS-A-Record auf den Backend-Server zeigen)
DOMAIN=join.api.sascha-gerspach.de
CERTBOT_EMAIL=admin@sascha-gerspach.de
